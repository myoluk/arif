# Runtime mode: local | dev | test
# local → Ollama + Gemma 4 E4B (no rate limit, offline)
# dev   → Gemini 2.5 Flash-Lite (fast iteration)
# test  → Gemini 2.5 Flash + Pro (production quality)
APP_ENV=dev

# Gemini API key - required for dev and test modes
# Get one free: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=arif-products

# Frontend URL - used for CORS
FRONTEND_URL=http://localhost:3000